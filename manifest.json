{
  "manifest_version": 3,
  "name": "TabLedger",
  "description": "Group open tabs into structured categories and save them into your Browsing Library.",
  "version": "0.1.0",
  "permissions": [
    "tabs",
    "bookmarks",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:4317/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_title": "TabLedger",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
