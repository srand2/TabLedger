{
  "manifest_version": 3,
  "name": "TabLedger",
  "description": "Group open tabs into structured categories and save them into your Browsing Library.",
  "version": "0.1.0",
  "permissions": [
    "tabs",
    "bookmarks",
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://www.youtube.com/*",
    "https://*.youtube.com/*"
  ],
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_title": "TabLedger",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
